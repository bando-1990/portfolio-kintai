<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- コンソール出力 -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- ファイル出力（日次ローテーション・30日保持） -->
  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>logs/kintai.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <!-- 毎日 logs/kintai.2026-05-24.log のようにローテーション -->
      <fileNamePattern>logs/kintai.%d{yyyy-MM-dd}.log</fileNamePattern>
      <maxHistory>30</maxHistory>
      <totalSizeCap>1GB</totalSizeCap>
    </rollingPolicy>
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- アプリ独自ログは INFO 以上を出力 -->
  <logger name="com.example.kintai" level="INFO"/>

  <!-- 開発環境のみ SQL ログを出力 -->
  <springProfile name="dev">
    <logger name="org.hibernate.SQL" level="DEBUG" additivity="false">
      <appender-ref ref="CONSOLE"/>
    </logger>
  </springProfile>

  <!-- ルートロガー：INFO 以上をコンソールとファイルに出力 -->
  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="FILE"/>
  </root>

</configuration>
